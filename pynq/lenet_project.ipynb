# ============================================================
# Cell 3: Allocate DDR buffer and write image
# ============================================================
input_buf = allocate(shape=(1024,), dtype=np.int16)
input_buf[:] = image_fixed
print(f"\nDDR buffer physical address: {hex(input_buf.physical_address)}")

# ============================================================
# Cell 4: Hardware Inference with timeout
# ============================================================
print("\n--- Hardware Inference (FPGA ap_fixed<16,8>) ---")

# Write DDR address to IP input register
lenet_ip.write(0x10, input_buf.physical_address & 0xFFFFFFFF)
print(f"Wrote input address: {hex(input_buf.physical_address & 0xFFFFFFFF)}")
print(f"Register 0x10 readback: {hex(lenet_ip.read(0x10))}")

# Start IP
lenet_ip.write(0x00, 0x01)
print("IP started, waiting for completion...")

# Wait with timeout
timeout  = 10000000
count    = 0
done     = False
while count < timeout:
    ctrl = lenet_ip.read(0x00)
    if ctrl & 0x02:  # ap_done
        done = True
        break
    count += 1

if done:
    print(f"IP finished after {count} polls")
else:
    print(f"TIMEOUT after {count} polls")
    ctrl = lenet_ip.read(0x00)
    print(f"  CTRL register : {ctrl:#010x}")
    print(f"  AP_START      : {(ctrl >> 0) & 1}")
    print(f"  AP_DONE       : {(ctrl >> 1) & 1}")
    print(f"  AP_IDLE       : {(ctrl >> 2) & 1}")
    print(f"  AP_READY      : {(ctrl >> 3) & 1}")

hw_pred = lenet_ip.read(lenet_ip.register_map.predicted_class.address)
print(f"\nPredicted class : {hw_pred}")
print(f"Expected class  : 29")
print(f"Result          : {'PASS' if hw_pred == 29 else 'FAIL'}")

# ============================================================
# Cell 5: If done, run 10x for timing
# ============================================================
if done:
    print("\n--- Running 10x for timing ---")
    hw_times = []
    for _ in range(10):
        start = time.perf_counter()
        lenet_ip.write(0x10, input_buf.physical_address & 0xFFFFFFFF)
        lenet_ip.write(0x00, 0x01)
        while not (lenet_ip.read(0x00) & 0x02):
            pass
        end = time.perf_counter()
        hw_times.append((end - start) * 1000)

    hw_avg = np.mean(hw_times)
    hw_min = np.min(hw_times)
    hw_max = np.max(hw_times)

    print("=" * 42)
    print(f"  Predicted Class : {hw_pred}")
    print(f"  Avg Latency     : {hw_avg:.4f} ms")
    print(f"  Min Latency     : {hw_min:.4f} ms")
    print(f"  Max Latency     : {hw_max:.4f} ms")
    print("=" * 42)

input_buf.freebuffer()

# ---- Weights must match parameters.h ----
# Since parameters.h is a C header we can't import directly,
# we use the fact that our HLS IP already has the correct weights
# and compare timing only — accuracy already confirmed as class 29

# Simple timing test: how long does ARM CPU take
# to do the equivalent floating point operations?

def relu(x):
    return np.maximum(0, x)

def conv2d_valid(inp, weights, bias):
    # inp: [C, H, W], weights: [F, C, kH, kW], bias: [F]
    F, C, kH, kW = weights.shape
    H_out = inp.shape[1] - kH + 1
    W_out = inp.shape[2] - kW + 1
    out = np.zeros((F, H_out, W_out), dtype=np.float32)
    for f in range(F):
        for h in range(H_out):
            for w in range(W_out):
                out[f,h,w] = np.sum(
                    inp[:, h:h+kH, w:w+kW] * weights[f]
                ) + bias[f]
    return relu(out)

def maxpool2d(inp, size=2):
    C, H, W = inp.shape
    out = np.zeros((C, H//size, W//size), dtype=np.float32)
    for c in range(C):
        for h in range(H//size):
            for w in range(W//size):
                out[c,h,w] = np.max(
                    inp[c, h*size:(h+1)*size, w*size:(w+1)*size]
                )
    return out

def fc(inp, weights, bias, activation=True):
    out = weights @ inp.flatten() + bias
    return relu(out) if activation else out

# Use random weights just for timing
# (we only care about execution time, not accuracy here)
np.random.seed(42)
conv1_w = np.random.randn(6,  1,  5, 5).astype(np.float32) * 0.1
conv1_b = np.random.randn(6).astype(np.float32)
conv2_w = np.random.randn(16, 6,  5, 5).astype(np.float32) * 0.1
conv2_b = np.random.randn(16).astype(np.float32)
fc1_w   = np.random.randn(120, 400).astype(np.float32) * 0.1
fc1_b   = np.random.randn(120).astype(np.float32)
fc2_w   = np.random.randn(84, 120).astype(np.float32) * 0.1
fc2_b   = np.random.randn(84).astype(np.float32)
fc3_w   = np.random.randn(43, 84).astype(np.float32) * 0.1
fc3_b   = np.random.randn(43).astype(np.float32)

test_image_sw = test_image.reshape(1, 32, 32)

print("--- Software Baseline (ARM CPU float) ---")
sw_times = []
for _ in range(10):
    start = time.perf_counter()
    c1 = conv2d_valid(test_image_sw, conv1_w, conv1_b)
    s2 = maxpool2d(c1)
    c3 = conv2d_valid(s2, conv2_w, conv2_b)
    s4 = maxpool2d(c3)
    f1 = fc(s4, fc1_w, fc1_b)
    f2 = fc(f1, fc2_w, fc2_b)
    f3 = fc(f2, fc3_w, fc3_b, activation=False)
    pred = np.argmax(f3)
    end = time.perf_counter()
    sw_times.append((end - start) * 1000)

sw_avg = np.mean(sw_times)
sw_min = np.min(sw_times)
sw_max = np.max(sw_times)

print(f"Avg Latency : {sw_avg:.4f} ms")
print(f"Min Latency : {sw_min:.4f} ms")
print(f"Max Latency : {sw_max:.4f} ms")

print("\n" + "=" * 42)
print("  FINAL COMPARISON")
print("=" * 42)
print(f"{'Version':<25} {'Latency (ms)':>12}")
print("-" * 42)
print(f"{'SW Float (ARM CPU)':<25} {sw_avg:>12.4f}")
print(f"{'HW ap_fixed (FPGA)':<25} {20.6701:>12.4f}")
